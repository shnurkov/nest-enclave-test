# Port the NestJS app listens on (see Dockerfile / enclaver.yaml -> ingress.listen_port)
PORT=4545

# AWS region for the KMS client.
# Only used for local runs (pnpm start:dev / node dist/main.js)
# and `docker run -e AWS_REGION=...`. For enclave builds .env isn't read —
# the value is baked into the image via `docker build --build-arg AWS_REGION=...`
# (see README), since enclaver run doesn't pass env vars into the enclave.
AWS_REGION=eu-central-1

# Do not set manually: Enclaver injects this variable inside the enclave itself
# (http://127.0.0.1:8000 -> kms_proxy.listen_port from enclaver.yaml) so that
# GenerateDataKeyPair/Decrypt requests go through the KMS proxy with attestation.
# Outside the enclave this variable must be unset — then the SDK talks to KMS
# directly via the regular AWS credential chain (useful for local debugging).
# AWS_KMS_ENDPOINT=http://127.0.0.1:8000
