# Порт, на котором слушает NestJS-приложение (см. Dockerfile / enclaver.yaml -> ingress.listen_port)
PORT=4545

# Регион AWS для KMS-клиента
AWS_REGION=eu-central-1

# Не задавать вручную: Enclaver сам прокидывает эту переменную внутрь энклава
# (http://127.0.0.1:8000 -> kms_proxy.listen_port из enclaver.yaml), чтобы запросы
# GenerateDataKeyPair/Decrypt шли через KMS proxy с attestation.
# Вне энклава переменная должна быть не задана — тогда SDK ходит в KMS напрямую
# по обычной AWS credential chain (полезно для локальной отладки).
# AWS_KMS_ENDPOINT=http://127.0.0.1:8000
